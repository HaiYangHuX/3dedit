{
  "name": "digital-twin-scene-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "copy:three-decoders": "node scripts/copy-three-decoders.mjs",
    "prebuild": "pnpm copy:three-decoders",
    "build": "pnpm -r --if-present build",
    "predev": "pnpm copy:three-decoders",
    "dev": "pnpm -r --parallel --if-present dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && stylelint --allow-empty-input \"apps/**/*.{css,scss,vue}\"",
    "test": "pnpm -r --if-present test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm -r --if-present typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/ws": "8.18.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "postcss-html": "1.8.1",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-config-standard": "40.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vue-eslint-parser": "10.4.1",
    "ws": "8.18.3"
  }
}
